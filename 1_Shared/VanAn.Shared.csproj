<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <WarningsAsErrors></WarningsAsErrors>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <AnalysisMode>Default</AnalysisMode>
    <NoWarn>$(NoWarn);CA1707;CA1848;CA1716;CS0579</NoWarn>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <Deterministic>false</Deterministic>
  </PropertyGroup>

  <Target Name="RemoveAutoGeneratedAttributes" BeforeTargets="GenerateAssemblyAttributes">
    <ItemGroup>
      <Compile Remove="$(IntermediateOutputPath)$(AssemblyName).AssemblyInfo.cs" />
      <Compile Remove="$(IntermediateOutputPath)*.AssemblyAttributes.cs" />
    </ItemGroup>
    <Message Text="Removed auto-generated assembly attributes for $(AssemblyName)" Importance="high" />
  </Target>

  <Target Name="SuppressDuplicateAttributes" BeforeTargets="CoreCompile">
    <ItemGroup>
      <Compile Remove="$(IntermediateOutputPath)*.AssemblyAttributes.cs" />
    </ItemGroup>
    <Message Text="Suppressed duplicate assembly attributes for $(AssemblyName)" Importance="high" />
  </Target>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="Microsoft.Extensions.Http" />
    <PackageReference Include="Microsoft.Extensions.Caching.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Serilog.Sinks.File" />
    <PackageReference Include="Serilog.Sinks.Console" />
    <PackageReference Include="Serilog.Sinks.Seq" />
    <PackageReference Include="Serilog.Extensions.Hosting" />
    <PackageReference Include="System.Text.Json" />
    <PackageReference Include="Microsoft.AspNetCore.SignalR.Client" />
    <PackageReference Include="Microsoft.AspNetCore.SignalR.Protocols.Json" />
  </ItemGroup>

</Project>
