<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VanAn.HRApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:VanAn.HRApp"
    xmlns:ui="clr-namespace:VanAn.HRApp.UI"
    Shell.FlyoutBehavior="Disabled"
    Title="ecoNexus HR">

    <!-- Login Route -->
    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate ui:LoginPage}"
        Route="login" />

    <!-- Main App Routes (accessible after login) -->
    <TabBar Route="main">
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
    </TabBar>

</Shell>
