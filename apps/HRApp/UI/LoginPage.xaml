<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VanAn.HRApp.UI.LoginPage"
             Title="Login - ecoNexus HR"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">
            
            <!-- Logo/Title -->
            <Image Source="dotnet_bot.png" 
                   HeightRequest="120" 
                   HorizontalOptions="Center" />
            
            <Label Text="ecoNexus HR"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#2E7D32" />

            <Label Text="Multi-Tenant HR Management"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="#666" />

            <!-- Login Form -->
            <Frame BackgroundColor="White" 
                   Padding="25" 
                   CornerRadius="10"
                   HasShadow="True">
                <VerticalStackLayout Spacing="15">
                    
                    <Label Text="Username" 
                           FontSize="14" 
                           TextColor="#333" />
                    
                    <Entry x:Name="UsernameEntry"
                           Placeholder="Enter username"
                           TextColor="#333"
                           BackgroundColor="#F8F8F8"
                           HeightRequest="45" />

                    <Label Text="Password" 
                           FontSize="14" 
                           TextColor="#333" />
                    
                    <Entry x:Name="PasswordEntry"
                           Placeholder="Enter password"
                           IsPassword="True"
                           TextColor="#333"
                           BackgroundColor="#F8F8F8"
                           HeightRequest="45" />

                    <Button x:Name="LoginButton"
                            Text="Login"
                            Clicked="OnLoginClicked"
                            BackgroundColor="#2E7D32"
                            TextColor="White"
                            HeightRequest="50"
                            CornerRadius="5" />

                    <Label x:Name="StatusLabel"
                           Text=""
                           TextColor="#D32F2F"
                           HorizontalOptions="Center"
                           FontSize="12" />

                </VerticalStackLayout>
            </Frame>

            <!-- Tenant Info (shown after login) -->
            <Frame x:Name="TenantFrame"
                   BackgroundColor="#E8F5E8"
                   Padding="20"
                   CornerRadius="10"
                   IsVisible="False">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Current Tenant"
                           FontSize="12"
                           TextColor="#2E7D32"
                           FontAttributes="Bold" />
                    <Label x:Name="TenantLabel"
                           Text=""
                           FontSize="14"
                           TextColor="#333" />
                    <Label x:Name="UserLabel"
                           Text=""
                           FontSize="12"
                           TextColor="#666" />
                </VerticalStackLayout>
            </Frame>

            <!-- Action Buttons (shown after login) -->
            <HorizontalStackLayout x:Name="ActionButtons"
                                  Spacing="10"
                                  IsVisible="False">
                <Button Text="Dashboard"
                        Clicked="OnDashboardClicked"
                        BackgroundColor="#1976D2"
                        TextColor="White"
                        HorizontalOptions="FillAndExpand" />
                <Button Text="Logout"
                        Clicked="OnLogoutClicked"
                        BackgroundColor="#757575"
                        TextColor="White"
                        HorizontalOptions="FillAndExpand" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
