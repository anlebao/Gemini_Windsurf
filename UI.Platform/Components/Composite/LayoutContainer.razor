@using Microsoft.AspNetCore.Components
@using VanAn.UI.Platform.Components.Base
@using VanAn.UI.Platform.Core.Interfaces
@using VanAn.UI.Platform.Adapters
@using VanAn.UI.Platform.Tokens
@using VanAn.UI.Platform.Components.Composite
@inherits BaseComponent

@inject ICssAdapter CssAdapter

<div class="@GetLayoutClasses()" @attributes="GetMergedAttributes()">
    @if (!string.IsNullOrEmpty(Header))
    {
        <header class="layout-header">
            @Header
        </header>
    }
    
    @if (Sidebar != null)
    {
        <aside class="layout-sidebar">
            @Sidebar
        </aside>
    }
    
    <main class="layout-main">
        @ChildContent
    </main>
    
    @if (!string.IsNullOrEmpty(Footer))
    {
        <footer class="layout-footer">
            @Footer
        </footer>
    }
</div>

@code {
    /// <summary>
    /// Layout variant
    /// </summary>
    [Parameter]
    public LayoutVariant Variant { get; set; } = LayoutVariant.Default;
    
    /// <summary>
    /// Header content
    /// </summary>
    [Parameter]
    public string? Header { get; set; }
    
    /// <summary>
    /// Footer content
    /// </summary>
    [Parameter]
    public string? Footer { get; set; }
    
    /// <summary>
    /// Sidebar content
    /// </summary>
    [Parameter]
    public RenderFragment? Sidebar { get; set; }
    
    /// <summary>
    /// Is fluid layout
    /// </summary>
    [Parameter]
    public bool Fluid { get; set; }
    
    /// <summary>
    /// Get layout CSS classes
    /// </summary>
    private string GetLayoutClasses()
    {
        var classes = new List<string>();
        
        // Base layout classes
        classes.Add("layout-container");
        
        // Variant classes
        classes.Add(Variant switch
        {
            LayoutVariant.Dashboard => "layout-dashboard",
            LayoutVariant.Admin => "layout-admin",
            LayoutVariant.Centered => "layout-centered",
            LayoutVariant.FullWidth => "layout-full-width",
            _ => "layout-default"
        });
        
        // Fluid layout
        if (Fluid)
            classes.Add("layout-fluid");
        
        return GetCombinedCssClass(classes.ToArray());
    }
}
}
