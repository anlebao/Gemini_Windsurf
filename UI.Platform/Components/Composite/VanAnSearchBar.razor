@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using VanAn.UI.Platform.Components.Base
@using VanAn.UI.Platform.Core.Interfaces
@using VanAn.UI.Platform.Adapters
@using VanAn.UI.Platform.Tokens
@inherits BaseComponent

@inject ICssAdapter CssAdapter

<div class="@GetSearchBarClasses()">
    <div class="search-input-group">
        @if (!string.IsNullOrEmpty(Placeholder))
        {
            <span class="search-icon">🔍</span>
        }
        <input type="text"
               id="search-input"
               class="search-input"
               placeholder="@Placeholder"
               value="@searchText"
               disabled="@IsDisabled"
               @oninput="HandleSearchInput"
               @onkeyup="HandleSearchKeyup" />
    </div>

    <button id="search-button" class="btn btn-search" @onclick="TriggerSearch" disabled="@IsDisabled">
        Tìm
    </button>

    @if (ShowAmountFilter)
    {
        <div class="amount-filter-group">
            <input type="number" id="amount-min" placeholder="Từ" @onchange="HandleAmountMinChange" />
            <input type="number" id="amount-max" placeholder="Đến" @onchange="HandleAmountMaxChange" />
        </div>
    }

    @if (ShowFilterButton)
    {
        <button id="filter-button" class="btn btn-filter" @onclick="HandleFilter" disabled="@IsDisabled">
            Filter
        </button>
    }
</div>

@code {
    /// <summary>
    /// Placeholder text for search input
    /// </summary>
    [Parameter]
    public string? Placeholder { get; set; } = "Search...";

    /// <summary>
    /// On search event callback (debounced)
    /// </summary>
    [Parameter]
    public EventCallback<string> OnSearch { get; set; }

    /// <summary>
    /// On filter button click callback
    /// </summary>
    [Parameter]
    public EventCallback OnFilter { get; set; }

    /// <summary>
    /// Show filter button
    /// </summary>
    [Parameter]
    public bool ShowFilterButton { get; set; }

    /// <summary>
    /// Is search bar disabled
    /// </summary>
    [Parameter]
    public bool IsDisabled { get; set; }

    /// <summary>
    /// Show amount filter inputs (min/max)
    /// </summary>
    [Parameter]
    public bool ShowAmountFilter { get; set; }

    /// <summary>
    /// Callback when amount min value changes
    /// </summary>
    [Parameter]
    public EventCallback<decimal?> AmountMinChanged { get; set; }

    /// <summary>
    /// Callback when amount max value changes
    /// </summary>
    [Parameter]
    public EventCallback<decimal?> AmountMaxChanged { get; set; }

    private string searchText = string.Empty;
    private decimal? amountMin;
    private decimal? amountMax;
    private System.Threading.Timer? debounceTimer;

    private void HandleSearchInput(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? string.Empty;
        DebounceSearch();
    }

    private void HandleSearchKeyup(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            CancelDebounce();
            TriggerSearch();
        }
    }

    private void DebounceSearch()
    {
        CancelDebounce();
        debounceTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(TriggerSearch);
        }, null, 300, System.Threading.Timeout.Infinite);
    }

    private void CancelDebounce()
    {
        debounceTimer?.Dispose();
        debounceTimer = null;
    }

    private async Task TriggerSearch()
    {
        if (OnSearch.HasDelegate)
        {
            await OnSearch.InvokeAsync(searchText);
        }
    }

    private async Task HandleFilter()
    {
        if (OnFilter.HasDelegate)
        {
            await OnFilter.InvokeAsync();
        }
    }

    private async Task HandleAmountMinChange(ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val))
        {
            amountMin = val;
            if (AmountMinChanged.HasDelegate)
                await AmountMinChanged.InvokeAsync(amountMin);
        }
    }

    private async Task HandleAmountMaxChange(ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val))
        {
            amountMax = val;
            if (AmountMaxChanged.HasDelegate)
                await AmountMaxChanged.InvokeAsync(amountMax);
        }
    }

    private string GetSearchBarClasses()
    {
        var baseClasses = CssAdapter.GetClasses("vanan-search-bar d-flex align-items-center gap-2");

        if (IsDisabled)
        {
            baseClasses += " disabled";
        }

        return GetCombinedCssClass(baseClasses);
    }

    public void Dispose()
    {
        CancelDebounce();
    }
}
