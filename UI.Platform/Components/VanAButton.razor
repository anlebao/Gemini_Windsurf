@* VanAButton Component - Phase 2.5.3: ShopERP Dashboard *@
@inherits VanAn.UI.Platform.Components.Base.VanAnComponentBase
@using Microsoft.Extensions.Logging
@inject ILogger<VanAButton> Logger

<button class="vanan-button @GetButtonClass()"
        type="@Type"
        disabled="@Disabled || Loading"
        @onclick="HandleClick"
        @attributes="AdditionalAttributes">
    @if (Loading)
    {
        <span class="vanan-button__spinner"></span>
    }
    
    @if (!string.IsNullOrEmpty(Icon) && Loading == false)
    {
        <span class="vanan-button__icon">@Icon</span>
    }
    
    <span class="vanan-button__text">@Text</span>
    
    @if (ChildContent != null && !Loading)
    {
        @ChildContent
    }
</button>

@code {
    [Parameter]
    public string Text { get; set; } = string.Empty;

    [Parameter]
    public string Variant { get; set; } = "primary"; // primary, secondary, success, warning, error, info, outline, ghost

    [Parameter]
    public string Size { get; set; } = "medium"; // small, medium, large

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool Loading { get; set; }

    [Parameter]
    public string? Icon { get; set; }

    [Parameter]
    public string? Type { get; set; } = "button"; // button, submit, reset

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private async Task HandleClick()
    {
        Logger.LogInformation("VanAButton HandleClick called - Type: {Type}, Text: {Text}, Disabled: {Disabled}, Loading: {Loading}", Type, Text, Disabled, Loading);
        if (!Disabled && !Loading)
        {
            Logger.LogInformation("VanAButton invoking OnClick callback");
            await OnClick.InvokeAsync();
        }
        else
        {
            Logger.LogInformation("VanAButton click blocked - Disabled: {Disabled}, Loading: {Loading}", Disabled, Loading);
        }
    }

    private async Task HandleClickWithSubmit()
    {
        if (!Disabled && !Loading)
        {
            await OnClick.InvokeAsync();
        }
    }

    protected override void OnInitialized()
    {
        Logger.LogInformation("VanAButton OnInitialized - Type: {Type}, Text: {Text}", Type, Text);
    }

    protected override void OnParametersSet()
    {
        Logger.LogInformation("VanAButton OnParametersSet - Type: {Type}, Text: {Text}", Type, Text);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        Logger.LogInformation("VanAButton OnAfterRender - Type: {Type}, Text: {Text}, firstRender: {FirstRender}", Type, Text, firstRender);
    }

    private string GetButtonClass()
    {
        var classes = new List<string>();

        // Variant classes
        classes.Add(Variant.ToLower() switch
        {
            "primary" => "vanan-button--primary",
            "secondary" => "vanan-button--secondary",
            "success" => "vanan-button--success",
            "warning" => "vanan-button--warning",
            "error" => "vanan-button--error",
            "info" => "vanan-button--info",
            "outline" => "vanan-button--outline",
            "ghost" => "vanan-button--ghost",
            _ => "vanan-button--primary"
        });

        // Size classes
        classes.Add(Size.ToLower() switch
        {
            "small" => "vanan-button--small",
            "large" => "vanan-button--large",
            _ => "vanan-button--medium"
        });

        // State classes
        if (Disabled) classes.Add("vanan-button--disabled");
        if (Loading) classes.Add("vanan-button--loading");
        if (!string.IsNullOrEmpty(Icon)) classes.Add("vanan-button--has-icon");

        return string.Join(" ", classes);
    }
}
