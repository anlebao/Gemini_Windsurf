<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="VanAn.ShopERP.styles.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    <script>
        // Reads current DOM values for the given element ids. Used as a robust
        // fallback for collecting form data at submit time, independent of binding timing.
        window.vananReadElementValue = function (id) {
            var el = document.getElementById(id);
            if (!el) return '';
            if (el.type === 'checkbox') return el.checked ? 'true' : 'false';
            return el.value ?? '';
        };
    </script>
</body>

</html>
