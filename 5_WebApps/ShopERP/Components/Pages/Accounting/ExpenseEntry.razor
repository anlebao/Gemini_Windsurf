@page "/accounting/expenses"
@rendermode InteractiveServer
@layout AccountingLayout
@using VanAn.UI.Platform.Components
@using PlatformComposite = VanAn.UI.Platform.Components.Composite
@using VanAn.UI.Platform.Models
@using Microsoft.AspNetCore.Components.Authorization
@using VanAn.Shared.Domain
@using CoreAccountingService = VanAn.CoreHub.Services
@using Microsoft.JSInterop
@inject CoreAccountingService.IAccountingService AccountingService
@inject IThemeProvider ThemeProvider
@inject AuthenticationStateProvider AuthStateProvider
@inject ILogger<ExpenseEntry> Logger
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<div class="expense-entry-page @ThemeProvider.CurrentTheme">
    <header class="page-header">
        <h1>Nhập Chi Phí</h1>
        <VanAButton 
            Variant="secondary" 
            Size="small"
            OnClick="GoBack">
            ← Quay Lại
        </VanAButton>
    </header>

    @if (showSuccess)
    {
        <VanAAlert data-testid="expense-success-alert" Variant="success" Message="Đã lưu chi phí thành công!" Dismissible="true" />
    }

    @if (showError)
    {
        <VanAAlert data-testid="expense-error-alert" Variant="error" Message="@errorMessage" Dismissible="true" />
    }

    <VanACard Header="Thông Tin Chi Phí">
        @* HARDENING KIẾN TRÚC: Đưa Form về trang Host quản lý *@
        <form @onsubmit="HandleSubmit" 
              @onsubmit:preventDefault
              data-blazor-interactive="@(_isInteractive.ToString().ToLower())">
            
            @* DynamicFormFields chỉ render fields, không giữ thẻ form, không giữ submit logic *@
            <DynamicFormFields FieldDefinitions="@expenseFields" />

            @* Nút bấm nằm tại trang Host sẽ nhận liên kết Interactive Server 100% chính xác *@
            <button type="@(_isInteractive ? "submit" : "button")" 
                    disabled="@(!_isInteractive)"
                    data-testid="expense-submit"
                    class="btn btn-primary">
                Lưu Chi Phí
            </button>
        </form>
    </VanACard>
</div>

@code {
    private List<VanAn.UI.Platform.Components.Composite.FormField> expenseFields = new();
    private bool showSuccess = false;
    private bool showError = false;
    private string errorMessage = string.Empty;
    private Guid _tenantId = Guid.Empty;
    private bool _isInteractive = false;

    protected override async Task OnInitializedAsync()
    {
        InitializeFields();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                var tenantIdClaim = user.FindFirst("TenantId");
                if (tenantIdClaim != null && Guid.TryParse(tenantIdClaim.Value, out var tenantId))
                {
                    _tenantId = tenantId;
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing ExpenseEntry");
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _isInteractive = true;
            Logger.LogInformation("ExpenseEntry Page Host - Interactivity established");
            StateHasChanged();
        }
    }

    private void InitializeFields()
    {
        var today = DateTime.Now.ToString("yyyy-MM-dd");

        expenseFields = new List<PlatformComposite.FormField>
        {
            new PlatformComposite.FormField
            {
                Id = "date",
                Label = "Ngày",
                Type = PlatformComposite.FieldType.Date,
                Value = today,
                Required = true,
                HelpText = "Ngày phát sinh chi phí"
            },
            new PlatformComposite.FormField
            {
                Id = "amount",
                Label = "Số Tiền (VNĐ)",
                Type = PlatformComposite.FieldType.Currency,
                Placeholder = "0.00",
                Required = true,
                HelpText = "Nhập số tiền chi phí"
            },
            new PlatformComposite.FormField
            {
                Id = "account",
                Label = "Tài Khoản",
                Type = PlatformComposite.FieldType.Select,
                Options = GetExpenseAccounts(),
                Required = true,
                HelpText = "Chọn tài khoản kế toán"
            },
            new PlatformComposite.FormField
            {
                Id = "vendor",
                Label = "Nhà Cung Cấp",
                Type = PlatformComposite.FieldType.Text,
                Placeholder = "Tên nhà cung cấp",
                HelpText = "Nhà cung cấp hàng hóa/dịch vụ"
            },
            new PlatformComposite.FormField
            {
                Id = "category",
                Label = "Loại Chi Phí",
                Type = PlatformComposite.FieldType.Select,
                Options = GetExpenseCategories(),
                Required = true,
                HelpText = "Phân loại chi phí"
            },
            new PlatformComposite.FormField
            {
                Id = "description",
                Label = "Diễn Giải",
                Type = PlatformComposite.FieldType.TextArea,
                Placeholder = "Nhập diễn giải giao dịch",
                Required = true,
                HelpText = "Mô tả chi tiết về chi phí"
            },
            new PlatformComposite.FormField
            {
                Id = "reference",
                Label = "Số Chứng Từ",
                Type = PlatformComposite.FieldType.Text,
                Placeholder = "VD: HĐ-001",
                HelpText = "Số hóa đơn hoặc chứng từ liên quan"
            }
        };
    }

    private List<PlatformComposite.FieldOption> GetExpenseAccounts()
    {
        return new List<PlatformComposite.FieldOption>
        {
            new PlatformComposite.FieldOption { Value = "621", Label = "621 - Chi phí nguyên vật liệu" },
            new PlatformComposite.FieldOption { Value = "622", Label = "622 - Chi phí nhân công" },
            new PlatformComposite.FieldOption { Value = "627", Label = "627 - Chi phí bán hàng" },
            new PlatformComposite.FieldOption { Value = "641", Label = "641 - Chi phí quản lý doanh nghiệp" },
            new PlatformComposite.FieldOption { Value = "642", Label = "642 - Chi phí tài chính" }
        };
    }

    private List<PlatformComposite.FieldOption> GetExpenseCategories()
    {
        return new List<PlatformComposite.FieldOption>
        {
            new PlatformComposite.FieldOption { Value = "materials", Label = "Nguyên vật liệu" },
            new PlatformComposite.FieldOption { Value = "labor", Label = "Nhân công" },
            new PlatformComposite.FieldOption { Value = "utilities", Label = "Điện nước" },
            new PlatformComposite.FieldOption { Value = "rent", Label = "Tiền thuê mặt bằng" },
            new PlatformComposite.FieldOption { Value = "marketing", Label = "Marketing & Quảng cáo" },
            new PlatformComposite.FieldOption { Value = "maintenance", Label = "Bảo trì & Sửa chữa" },
            new PlatformComposite.FieldOption { Value = "other", Label = "Khác" }
        };
    }

    private record RecentEntry(decimal Amount, DateTime Date, string AccountCode, DateTime SubmittedAt);
    private List<RecentEntry> _recentEntries = new();

    private static readonly HashSet<string> VendorRequiredCategories = new() { "materials", "maintenance" };

    private async Task HandleSubmit()
    {
        Logger.LogInformation("ExpenseEntry HandleSubmit ENTERED");
        try
        {
            showSuccess = false;
            showError = false;
            Logger.LogInformation("Reset flags: showSuccess={showSuccess}, showError={showError}", showSuccess, showError);

            // TODO: [TECH DEBT] [VẠN AN PLATFORM HARDENING]
            // Fallback tenant hardcode cho E2E testing vì login demo không set TenantId claim.
            // Sửa triệt để: thêm claim TenantId khi login, xóa fallback.
            // Tier: 1 (Tenant - ưu tiên cao)
            if (_tenantId == Guid.Empty)
            {
                _tenantId = Guid.Parse("00000000-0000-0000-0000-000000000001");
                Logger.LogInformation("Using fallback tenant ID");
            }
            Logger.LogInformation("TenantId: {TenantId}", _tenantId);

            // TODO: [TECH DEBT] [VẠN AN PLATFORM HARDENING]
            // Workaround JS Interop đọc DOM do rớt binding ranh giới Component.
            // Sẽ refactor sang cơ chế Event Callback chuẩn sau khi Baseline E2E ổn định.
            // Tier: 2 (Binding - ưu tiên sau Tenant)
            // CRITICAL FIX: Always read DOM value for amount/category to ensure E2E fills are captured.
            // Blazor @bind can drop events during fast Playwright fills; DOM is source of truth.
            var formData = new PlatformComposite.FormData();
            var criticalFields = new HashSet<string> { "amount", "category", "vendor", "description", "entryDate" };
            foreach (var field in expenseFields)
            {
                string value;
                // Always read from DOM for critical fields to handle binding race conditions
                if (criticalFields.Contains(field.Id))
                {
                    try
                    {
                        value = await JSRuntime.InvokeAsync<string>("vananReadElementValue", field.Id) ?? string.Empty;
                        // If DOM is empty, fall back to model value as safety net
                        if (string.IsNullOrEmpty(value))
                        {
                            value = field.Value?.ToString() ?? string.Empty;
                        }
                    }
                    catch (Exception ex)
                    {
                        Logger.LogWarning(ex, "JS interop read failed for critical field {FieldId}, using model fallback", field.Id);
                        value = field.Value?.ToString() ?? string.Empty;
                    }
                }
                else
                {
                    value = field.Value?.ToString() ?? string.Empty;
                }
                formData.Values[field.Id] = value;
                Logger.LogInformation("Field {FieldId}: '{FieldValue}' (source: {Source})", field.Id, value, criticalFields.Contains(field.Id) ? "DOM" : "model");
            }

            // Validate amount - support both raw and formatted numbers (500000 or 500.000)
            Logger.LogInformation("Validating amount: {Amount}", formData.Values["amount"]);
            var amountStr = formData.Values["amount"].Replace(".", "").Replace(",", "");
            if (!decimal.TryParse(amountStr, out var amount) || amount <= 0)
            {
                Logger.LogWarning("Amount validation failed for: {AmountStr}", amountStr);
                showError = true;
                errorMessage = "Số tiền phải lớn hơn 0";
                StateHasChanged();
                return;
            }
            Logger.LogInformation("Amount validation passed: {Amount}", amount);

            // Validate date
            Logger.LogInformation("Validating date: {Date}", formData.Values["date"]);
            if (!DateTime.TryParse(formData.Values["date"], out var date))
            {
                Logger.LogWarning("Date validation failed");
                showError = true;
                errorMessage = "Ngày không hợp lệ";
                StateHasChanged();
                return;
            }
            Logger.LogInformation("Date validation passed: {Date}", date);

            // Validate account code format (must be 6xx for expense)
            var accountCode = formData.Values.GetValueOrDefault("account") ?? string.Empty;
            Logger.LogInformation("Validating account code: {AccountCode}", accountCode);
            if (string.IsNullOrEmpty(accountCode) || !IsValidExpenseAccountCode(accountCode))
            {
                Logger.LogWarning("Account code validation failed");
                showError = true;
                errorMessage = "Mã tài khoản không hợp lệ. Chi phí phải thuộc nhóm 6xx.";
                StateHasChanged();
                return;
            }
            Logger.LogInformation("Account code validation passed");

            // Vendor required for material/maintenance categories
            var category = formData.Values.GetValueOrDefault("category") ?? string.Empty;
            var vendor = formData.Values.GetValueOrDefault("vendor") ?? string.Empty;
            Logger.LogInformation("Validating vendor: Category={Category}, Vendor={Vendor}", category, vendor);
            if (VendorRequiredCategories.Contains(category) && string.IsNullOrWhiteSpace(vendor))
            {
                Logger.LogWarning("Vendor validation failed - vendor required for category {Category}", category);
                showError = true;
                errorMessage = "Nhà cung cấp bắt buộc khi loại chi phí là Nguyên vật liệu hoặc Bảo trì & Sửa chữa.";
                StateHasChanged();
                return;
            }
            Logger.LogInformation("Vendor validation passed");

            // Duplicate check: same amount + date + account within 5 minutes
            var now = DateTime.Now;
            _recentEntries.RemoveAll(e => (now - e.SubmittedAt).TotalMinutes > 5);
            var duplicate = _recentEntries.FirstOrDefault(e =>
                e.Amount == amount && e.Date.Date == date.Date && e.AccountCode == accountCode);

            if (duplicate != null)
            {
                Logger.LogWarning("Duplicate entry detected");
                showError = true;
                errorMessage = "Phát hiện bút toán trùng lặp (cùng số tiền, ngày, tài khoản trong 5 phút). Vui lòng kiểm tra lại.";
                StateHasChanged();
                return;
            }
            Logger.LogInformation("Duplicate check passed");

            // Create accounting period
            var period = new AccountingPeriod(date.Year, date.Month);
            var tenantId = new TenantId(_tenantId);
            Logger.LogInformation("Calling AccountingService.CreateExpenseEntryAsync with Period={Period}, Amount={Amount}", period, amount);

            // Create accounting entry using IAccountingService
            await AccountingService.CreateExpenseEntryAsync(
                tenantId,
                period,
                amount,
                formData.Values["description"]);

            Logger.LogInformation("AccountingService.CreateExpenseEntryAsync completed successfully");

            // Track for duplicate detection
            _recentEntries.Add(new RecentEntry(amount, date, accountCode, now));

            showSuccess = true;
            showError = false;
            errorMessage = string.Empty;
            Logger.LogInformation("Setting success state: showSuccess={showSuccess}, showError={showError}", showSuccess, showError);
            StateHasChanged();
            Logger.LogInformation("StateHasChanged called");

            // Reset form
            InitializeFields();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving expense entry for tenant {TenantId}", _tenantId);
            showError = true;
            errorMessage = $"Lỗi khi lưu: {ex.Message}";
            Logger.LogInformation("Setting error state: showError={showError}, errorMessage={errorMessage}", showError, errorMessage);
            StateHasChanged();
        }
    }

    private static bool IsValidExpenseAccountCode(string code)
    {
        if (code.Length != 3) return false;
        return code.StartsWith("6");
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/accounting");
    }
}
