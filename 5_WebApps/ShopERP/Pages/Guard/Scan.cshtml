@page "/guard/scan"
@using VanAn.Shared.Domain
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Guard")]

@{
    ViewData["Title"] = "Guard Scanner";
    var displayName = User.FindFirst("DisplayName")?.Value ?? "Bảo vệ";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Guard Scanner - @displayName</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <style>
        .scanner-container {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        .qr-frame {
            border: 3px solid #10b981;
            border-radius: 12px;
            position: relative;
        }
        .qr-frame::before,
        .qr-frame::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            border: 3px solid #10b981;
        }
        .qr-frame::before {
            top: -3px;
            left: -3px;
            border-right: none;
            border-bottom: none;
        }
        .qr-frame::after {
            bottom: -3px;
            right: -3px;
            border-left: none;
            border-top: none;
        }
        .pulse-animation {
            animation: pulse 2s infinite;
        }
        @@keyframes pulse {
            0% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.05); opacity: 0.8; }
            100% { transform: scale(1); opacity: 1; }
        }
        @@media (max-width: 768px) {
            .scanner-container {
                padding: 1rem;
            }
            .qr-frame {
                width: 200px;
                height: 200px;
            }
        }
    </style>
</head>
<body class="bg-gray-100">
    
    <!-- Navigation -->
    <nav class="bg-green-600 text-white shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <h1 class="text-xl font-bold">🛡️ Guard Scanner</h1>
                </div>
                <div class="flex items-center">
                    <span class="mr-4">👋 @displayName</span>
                    <form method="post" asp-page="/Logout">
                        <button type="submit" class="bg-red-500 hover:bg-red-600 text-white px-3 py-1 rounded text-sm">
                            Đăng xuất
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Scanner Interface -->
    <main class="scanner-container min-h-screen flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl p-8 max-w-md w-full">
            
            <!-- Scanner Header -->
            <div class="text-center mb-8">
                <div class="w-24 h-24 bg-green-500 rounded-full flex items-center justify-center mx-auto mb-4 pulse-animation">
                    <span class="text-white text-4xl">📱</span>
                </div>
                <h2 class="text-2xl font-bold text-gray-900 mb-2">Quét mã QR</h2>
                <p class="text-gray-600">Đưa mã QR của khách hoặc xe vào để quét</p>
            </div>
            
            <!-- QR Scanner Area -->
            <div class="qr-frame w-64 h-64 mx-auto mb-8 flex items-center justify-center bg-gray-900">
                <div class="text-center">
                    <div class="text-green-400 text-6xl mb-2">📷</div>
                    <p class="text-green-400 text-sm">Camera Ready</p>
                </div>
            </div>
            
            <!-- Action Buttons -->
            <div class="space-y-4">
                <button class="w-full bg-green-500 hover:bg-green-600 text-white font-bold py-4 px-6 rounded-lg text-lg transition-colors">
                    📷 Bắt đầu quét QR
                </button>
                
                <div class="grid grid-cols-2 gap-4">
                    <button class="bg-green-50 hover:bg-green-100 text-green-700 py-3 px-4 rounded-lg font-semibold transition-colors">
                        ✅ Check-in
                    </button>
                    <button class="bg-red-50 hover:bg-red-100 text-red-700 py-3 px-4 rounded-lg font-semibold transition-colors">
                        ❌ Check-out
                    </button>
                </div>
            </div>
            
            <!-- Recent Activity -->
            <div class="mt-8 pt-6 border-t border-gray-200">
                <h3 class="text-sm font-semibold text-gray-900 mb-4">Hoạt động gần đây:</h3>
                <div class="space-y-2 max-h-32 overflow-y-auto">
                    <div class="flex justify-between items-center text-sm p-2 bg-gray-50 rounded">
                        <span>🚗 Biển số 30A-12345</span>
                        <span class="text-gray-500">2 phút trước</span>
                    </div>
                    <div class="flex justify-between items-center text-sm p-2 bg-gray-50 rounded">
                        <span>👤 Khách VIP-001</span>
                        <span class="text-gray-500">5 phút trước</span>
                    </div>
                    <div class="flex justify-between items-center text-sm p-2 bg-gray-50 rounded">
                        <span>🚗 Biển số 51B-67890</span>
                        <span class="text-gray-500">8 phút trước</span>
                    </div>
                </div>
            </div>
            
            <!-- Quick Stats -->
            <div class="mt-6 grid grid-cols-3 gap-4 text-center">
                <div class="bg-blue-50 p-3 rounded">
                    <div class="text-2xl font-bold text-blue-600">24</div>
                    <div class="text-xs text-gray-600">Check-in hôm nay</div>
                </div>
                <div class="bg-orange-50 p-3 rounded">
                    <div class="text-2xl font-bold text-orange-600">18</div>
                    <div class="text-xs text-gray-600">Check-out hôm nay</div>
                </div>
                <div class="bg-green-50 p-3 rounded">
                    <div class="text-2xl font-bold text-green-600">6</div>
                    <div class="text-xs text-gray-600">Đang trong bãi</div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="fixed bottom-0 left-0 right-0 bg-green-600 text-white p-2 text-center text-sm">
        Vạn An Group - Guard Scanner v1.0 | 📞 Hotline: 1900-8888
    </footer>

</body>
</html>
