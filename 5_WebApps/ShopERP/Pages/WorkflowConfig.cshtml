@page "/workflow-config"
@using VanAn.Shared.Domain

<PageTitle>ShopERP - Cấu hình Workflow</PageTitle>

<div class="container">
    <h2>⚙️ Cấu hình Workflow</h2>
    
    <div class="row">
        @foreach (var status in OrderStatuses.Default)
        {
            <div class="col-md-6 mb-3">
                <div class="card @(status.IsActive ? "border-primary" : "border-secondary")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h5>@status.DisplayName</h5>
                                <small class="text-muted">Sequence: @status.Sequence</small>
                                @if (status.RequiresInventoryDeduction)
                                {
                                    <div class="mt-1">
                                        <span class="badge bg-warning">
                                            <i class="fas fa-boxes"></i> Sẽ trừ kho
                                        </span>
                                    </div>
                                }
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" 
                                       checked="@status.IsActive" 
                                       onchange="ToggleStatus('@status.Id.Value', this.checked)">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    
    <div class="mt-4">
        <button class="btn btn-primary" onclick="SaveConfig()">
            <i class="fas fa-save"></i> Lưu cấu hình
        </button>
        <a href="/" class="btn btn-secondary ms-2">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

@functions {
    private void ToggleStatus(string statusId, bool isActive)
    {
        // Toggle logic here
    }
    
    private void SaveConfig()
    {
        // Save configuration
    }
}
