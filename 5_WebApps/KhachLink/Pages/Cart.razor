@using VanAn.KhachLink.Components.Layout
@page "/cart"
@inject VanAn.KhachLink.Services.CartService CartService
@inject NavigationManager Navigation
@inject IThemeProvider ThemeProvider
@inject ITenantService TenantService
@implements IDisposable

<PageTitle>Giỏ hàng - KhachLink</PageTitle>

<KhachLinkLayout>
    <div class="container py-4">
        <h2 class="mb-4">🛒 Giỏ hàng của bạn</h2>

        @if (cartState.GetTotalItems() == 0)
        {
            <VanAnAlert Variant="AlertVariant.Info" Message="Giỏ hàng của bạn đang trống. Hãy thêm sản phẩm để tiếp tục!" />
            <div class="text-center mt-3">
                <VanAnButton Icon="house" OnClick="@(() => Navigation.NavigateTo("/"))">
                    Quay lại trang chủ
                </VanAnButton>
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-md-8">
                    <VanAnCard Header="Sản phẩm đã chọn">
                        <div class="cart-items">
                            @foreach (var item in cartState.Items)
                            {
                                <VanAnCard CssClass="cart-item mb-3">
                                    <div class="row align-items-center">
                                        <div class="col-md-6">
                                            <h6>@item.ProductName</h6>
                                            <small class="text-muted">@item.Description</small>
                                            <div class="mt-2">
                                                <span class="badge bg-success">@item.UnitPrice.ToString("N0") VNĐ</span>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="quantity-control">
                                                <div class="input-group" style="width: 120px;">
                                                    <VanAnButton Size="ButtonSize.Small" CssClass="btn-outline-secondary" OnClick="() => UpdateQuantity(item.ProductId, item.Quantity - 1)">-</VanAnButton>
                                                    <input type="number" class="form-control text-center" value="@item.Quantity" @oninput="@(e => UpdateQuantity(item.ProductId, Convert.ToInt32(e.Value ?? "0")))" min="1" />
                                                    <VanAnButton Size="ButtonSize.Small" CssClass="btn-outline-secondary" OnClick="() => UpdateQuantity(item.ProductId, item.Quantity + 1)">+</VanAnButton>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-3 text-end">
                                            <VanAnButton Variant="ButtonVariant.Danger" Size="ButtonSize.Small" Icon="trash" OnClick="() => RemoveItem(item.ProductId)">
                                                Xóa
                                            </VanAnButton>
                                        </div>
                                    </div>
                                </VanAnCard>
                            }
                        </div>
                    </VanAnCard>
                </div>
                
                <div class="col-md-4">
                    <VanAnCard Header="💰 Chi tiết thanh toán">
                        <div class="payment-summary">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Tạm tính:</span>
                                <strong>@cartState.SubTotal.ToString("N0") VNĐ</strong>
                            </div>
                            <hr />
                            <div class="d-flex justify-content-between mb-3">
                                <h5>Tổng cộng:</h5>
                                <h5 class="text-danger">@cartState.TotalAmount.ToString("N0") VNĐ</h5>
                            </div>
                            <VanAnButton Variant="ButtonVariant.Success" FullWidth="true" Icon="qr-code" OnClick="ProceedToCheckout">
                                Thanh toán
                            </VanAnButton>
                            <VanAnButton Variant="ButtonVariant.Outline" FullWidth="true" CssClass="mt-2" OnClick="ClearCart">
                                Xóa giỏ hàng
                            </VanAnButton>
                        </div>
                    </VanAnCard>
                </div>
            </div>
        }
    </div>
</KhachLinkLayout>

@code {
    private VanAn.KhachLink.Services.CartState cartState = new();
    
    protected override async Task OnInitializedAsync()
    {
        cartState = CartService.GetCartState();
        CartService.OnCartChanged += StateHasChanged;
        await CartService.LoadCartFromStorageAsync();
    }

    private async Task UpdateQuantity(Guid productId, int quantity)
    {
        await CartService.UpdateQuantityAsync(productId, quantity);
    }

    private async Task RemoveItem(Guid productId)
    {
        await CartService.RemoveItemAsync(productId);
    }

    private async Task ClearCart()
    {
        await CartService.ClearCartAsync();
    }

    private void ProceedToCheckout()
    {
        Navigation.NavigateTo("/checkout");
    }

    public void Dispose()
    {
        CartService.OnCartChanged -= StateHasChanged;
    }
}
