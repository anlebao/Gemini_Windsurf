@page "/"
@using VanAn.KhachLink.Components.Layout
@using VanAn.UI.Platform.Components.Atomic

<PageTitle>Vạn An Group - Hệ thống đặt hàng thông minh</PageTitle>

<VanAnLayout ActivePage="home">
    <div class="container mx-auto px-4 py-8">
        <!-- Hero Section -->
        <section class="text-center py-12 md:py-20">
            <div class="max-w-4xl mx-auto">
                <h1 class="text-4xl md:text-6xl font-bold text-gray-900 mb-6">
                    Vạn An Group
                </h1>
                <p class="text-xl md:text-2xl text-gray-600 mb-8">
                    🍹 Đặt hàng nhanh - Theo dõi thông minh - Trải nghiệm hoàn hảo
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <VanAnButton Variant="ButtonVariant.Primary" Size="ButtonSize.Large" FullWidth="true" Icon="play">
                        Bắt đầu đặt hàng
                    </VanAnButton>
                    <VanAnButton Variant="ButtonVariant.Outline" Size="ButtonSize.Large" FullWidth="true" Icon="mobile-alt">
                        Tải ứng dụng
                    </VanAnButton>
                </div>
            </div>
        </section>

        <!-- Features Grid -->
        <section class="py-16">
            <div class="text-center mb-12">
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
                    Tại sao chọn Vạn An?
                </h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    Nền tảng đặt hàng thông minh được thiết kế cho quán cà phê và trà sữa hiện đại
                </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <VanAnCard Hoverable="true">
                    <Header>
                        <div class="flex items-center gap-3">
                            <div class="w-12 h-12 bg-primary bg-opacity-10 rounded-lg flex items-center justify-center">
                                <i class="fas fa-mobile-alt text-primary text-xl"></i>
                            </div>
                            <h3 class="text-xl font-semibold">Mobile First</h3>
                        </div>
                    </Header>
                    <div class="card-body">
                        <p class="text-gray-600 mb-4">
                            Giao diện tối ưu cho di động, đặt hàng chỉ với 3 thao tác đơn giản.
                        </p>
                        <ul class="space-y-2 text-gray-600">
                            <li class="flex items-center gap-2">
                                <i class="fas fa-check text-success text-sm"></i>
                                <span>Responsive design</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class="fas fa-check text-success text-sm"></i>
                                <span>Touch-friendly</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class="fas fa-check text-success text-sm"></i>
                                <span>PWA support</span>
                            </li>
                        </ul>
                    </div>
                </VanAnCard>

                <VanAnCard Hoverable="true">
                    <Header>
                        <div class="flex items-center gap-3">
                            <div class="w-12 h-12 bg-secondary bg-opacity-10 rounded-lg flex items-center justify-center">
                                <i class="fas fa-clock text-secondary text-xl"></i>
                            </div>
                            <h3 class="text-xl font-semibold">Real-time Tracking</h3>
                        </div>
                    </Header>
                    <div class="card-body">
                        <p class="text-gray-600 mb-4">
                            Theo dõi đơn hàng real-time với thanh tiến độ động và thông báo tức thì.
                        </p>
                        <ul class="space-y-2 text-gray-600">
                            <li class="flex items-center gap-2">
                                <i class="fas fa-check text-success text-sm"></i>
                                <span>Live updates</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class="fas fa-check text-success text-sm"></i>
                                <span>Push notifications</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class="fas fa-check text-success text-sm"></i>
                                <span>Dashboard analytics</span>
                            </li>
                        </ul>
                    </div>
                </VanAnCard>

                <VanAnCard Hoverable="true">
                    <Header>
                        <div class="flex items-center gap-3">
                            <div class="w-12 h-12 bg-accent bg-opacity-10 rounded-lg flex items-center justify-center">
                                <i class="fas fa-bolt text-accent text-xl"></i>
                            </div>
                            <h3 class="text-xl font-semibold">Zero-Friction</h3>
                        </div>
                    </Header>
                    <div class="card-body">
                        <p class="text-gray-600 mb-4">
                            Không cần đăng nhập, nhận diện tự động qua Device ID và QR code.
                        </p>
                        <ul class="space-y-2 text-gray-600">
                            <li class="flex items-center gap-2">
                                <i class="fas fa-check text-success text-sm"></i>
                                <span>No registration</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class="fas fa-check text-success text-sm"></i>
                                <span>Auto device detection</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class="fas fa-check text-success text-sm"></i>
                                <span>Instant access</span>
                            </li>
                        </ul>
                    </div>
                </VanAnCard>
            </div>
        </section>

        <!-- Stats Section -->
        <section class="py-16 bg-gray-50 rounded-2xl">
            <div class="container mx-auto px-8">
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
                    <div class="text-center">
                        <div class="text-4xl font-bold text-primary mb-2">1000+</div>
                        <div class="text-gray-600">Quán đã tin dùng</div>
                    </div>
                    <div class="text-center">
                        <div class="text-4xl font-bold text-secondary mb-2">50K+</div>
                        <div class="text-gray-600">Đơn hàng/ngày</div>
                    </div>
                    <div class="text-center">
                        <div class="text-4xl font-bold text-accent mb-2">99.9%</div>
                        <div class="text-gray-600">Uptime</div>
                    </div>
                    <div class="text-center">
                        <div class="text-4xl font-bold text-success mb-2">4.9★</div>
                        <div class="text-gray-600">Đánh giá</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="py-16 text-center">
            <div class="max-w-2xl mx-auto">
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
                    🚀 Trải nghiệm ngay hôm nay
                </h2>
                <p class="text-lg text-gray-600 mb-8">
                    Hệ thống đã sẵn sàng cho bạn trải nghiệm đặt hàng thông minh
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <VanAnButton Variant="ButtonVariant.Primary" Size="ButtonSize.Large" Icon="rocket">
                        Bắt đầu miễn phí
                    </VanAnButton>
                    <VanAnButton Variant="ButtonVariant.Outline" Size="ButtonSize.Large" Icon="phone">
                        Liên hệ hỗ trợ
                    </VanAnButton>
                </div>
            </div>
        </section>
    </div>
</VanAnLayout>
