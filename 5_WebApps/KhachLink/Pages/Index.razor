@page "/"
@using VanAn.Shared.Domain
@using VanAn.Shared.Extensions
@using VanAn.KhachLink.Models
@using VanAn.KhachLink.Components
@using VanAn.KhachLink.Components.Shared
@using System.Globalization

<DynamicThemeProvider OnShopConfigLoaded="OnShopConfigLoaded">
    <div class="vanan-container">
        <!-- Hero Section -->
        <section class="hero-section">
            <div class="container text-center">
                <h1 class="hero-title">@pageTitle</h1>
                <p class="hero-subtitle">Đặt hàng nhanh chóng, tiện lợi</p>
            </div>
        </section>

        <!-- Social Hub -->
        <SocialHub ShopConfig="@ShopConfig" />

        <!-- Vibe Product Grid -->
        <VibeProductGrid ShopConfig="@ShopConfig" Products="@SampleProducts" AddToCart="AddToCart" />

        <!-- Cart Drawer -->
        <CartDrawer CartItems="@cartItems" TotalAmount="@totalAmount" RemoveFromCart="RemoveFromCart" Checkout="Checkout" />

        <!-- Order Tracking -->
        @if (currentOrder != null)
        {
            <section class="order-tracking">
                <div class="container">
                    <div class="tracking-card">
                        <div class="tracking-header">
                            <h4>📋 Theo dõi đơn hàng</h4>
                            <span class="order-id">#@currentOrder.DisplayId</span>
                        </div>
                        <div class="tracking-progress">
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: @orderProgress%">
                                    @orderProgress%
                                </div>
                            </div>
                        </div>
                        <div class="tracking-info">
                            <p>Trạng thái: <strong>@currentOrder.StatusDisplay</strong></p>
                            <p>Thời gian: <strong>@currentOrder.EstimatedMinutes phút</strong></p>
                        </div>
                    </div>
                </div>
            </section>
        }

        <!-- App Install Prompt -->
        <AppInstallPrompt />
    </div>
</DynamicThemeProvider>

<style>
    .vanan-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    }

    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 80px 0;
        margin-bottom: 40px;
        border-radius: 0 0 50px 50px;
    }

    .hero-title {
        font-size: 3.5rem;
        font-weight: bold;
        margin-bottom: 1rem;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }

    .hero-subtitle {
        font-size: 1.3rem;
        opacity: 0.9;
        margin-bottom: 0;
    }

    .order-tracking {
        margin-top: 40px;
        padding: 0 20px 40px;
    }

    .tracking-card {
        background: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .tracking-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .tracking-header h4 {
        margin: 0;
        color: #333;
    }

    .order-id {
        background: #007bff;
        color: white;
        padding: 5px 12px;
        border-radius: 15px;
        font-size: 0.9rem;
        font-weight: bold;
    }

    .progress-bar {
        width: 100%;
        height: 20px;
        background-color: #f0f0f0;
        border-radius: 10px;
        overflow: hidden;
        margin: 15px 0;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg, #4CAF50, #45a049);
        transition: width 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 12px;
        font-weight: bold;
    }

    .tracking-info {
        display: flex;
        justify-content: space-between;
        margin-top: 20px;
    }

    .tracking-info p {
        margin: 0;
        color: #666;
    }

    @@media (max-width: 768px) {
        .hero-title {
            font-size: 2.5rem;
        }

        .tracking-info {
            flex-direction: column;
            gap: 10px;
        }
    }
</style>

@code {
    private ShopConfig? ShopConfig { get; set; }
    private string shopName = "Vạn An Group";
    private string shopLogoUrl = "/images/logo.png";
    private string pageTitle = "Vạn An Group - Đặt hàng nhanh";
    private List<CartItem> cartItems = new();
    private OrderInfo? currentOrder { get; set; }
    private int orderProgress { get; set; }

    private static readonly List<CartItem> SampleProducts = new()
    {
        new() { Id = Guid.NewGuid(), ProductId = Guid.NewGuid(), ProductName = "Trà sữa", Description = "Trà sữa truyền thống", UnitPrice = 25000, Quantity = 1 },
        new() { Id = Guid.NewGuid(), ProductId = Guid.NewGuid(), ProductName = "Cà phê", Description = "Cà phê đen đá", UnitPrice = 18000, Quantity = 1 },
        new() { Id = Guid.NewGuid(), ProductId = Guid.NewGuid(), ProductName = "Nước ép", Description = "Nước ép trái cây", UnitPrice = 22000, Quantity = 1 },
        new() { Id = Guid.NewGuid(), ProductId = Guid.NewGuid(), ProductName = "Trà vải", Description = "Trà vải tươi", UnitPrice = 32000, Quantity = 1 }
    };

    private decimal totalAmount => cartItems.Sum(item => (decimal)item.Quantity * item.UnitPrice);

    private async Task OnShopConfigLoaded(ShopConfig config)
    {
        ShopConfig = config;
        shopName = config?.ShopName ?? "Vạn An Group";
        shopLogoUrl = config?.LogoUrl?.ToString() ?? "/images/default-logo.png";
        pageTitle = $"{shopName} - Đặt hàng nhanh";
        
        StateHasChanged();
        await Task.CompletedTask;
    }

    private void AddToCart(CartItem product)
    {
        var existingItem = cartItems.FirstOrDefault(item => item.Id == product.Id);
        if (existingItem != null)
        {
            // Create new item with updated quantity (record is immutable)
            cartItems = cartItems.Where(item => item.Id != product.Id).ToList();
            cartItems.Add(existingItem with { Quantity = existingItem.Quantity + 1 });
        }
        else
        {
            cartItems.Add(new CartItem
            {
                Id = Guid.NewGuid(),
                ProductId = product.ProductId,
                ProductName = product.ProductName,
                Description = product.Description,
                Quantity = 1,
                UnitPrice = product.UnitPrice
            });
        }
        StateHasChanged();
    }

    private void RemoveFromCart(Guid productId)
    {
        cartItems.RemoveAll(x => x.Id == productId);
        StateHasChanged();
    }

    private async Task Checkout()
    {
        if (!cartItems.Any()) return;
        
        // Create order logic here
        currentOrder = new OrderInfo
        {
            Id = Guid.NewGuid(),
            Status = "Đang chuẩn bị",
            EstimatedMinutes = 15,
            TotalAmount = totalAmount,
            Items = cartItems.ToList()
        };
        orderProgress = 25;
        
        StateHasChanged();
        
        // Simulate order progress
        for (int i = 0; i < 4; i++)
        {
            await Task.Delay(2000);
            orderProgress += 25;
            
            // Update order status based on progress
            currentOrder.Status = orderProgress switch
            {
                25 => "Đã xác nhận",
                50 => "Đang pha chế", 
                75 => "Sẵn sàng",
                100 => "Hoàn thành",
                _ => currentOrder.Status
            };
            
            StateHasChanged();
        }
        
        // Clear cart
        cartItems.Clear();
        await Task.Delay(1000);
        currentOrder = null;
        orderProgress = 0;
        StateHasChanged();
    }
}
