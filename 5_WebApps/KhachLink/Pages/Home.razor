@using VanAn.KhachLink.Components.Layout
@using VanAn.Shared.Domain
@page "/home"
@inject VanAn.KhachLink.Services.CartService CartService
@inject NavigationManager Navigation
@inject IThemeProvider ThemeProvider
@inject ITenantService TenantService
@implements IDisposable

<PageTitle>KhachLink - Cỗ Máy Giữ Khách Vạn An</PageTitle>

<!-- Cart Drawer Component -->
<CartDrawer 
    CartItems="@cartState.Items"
    TotalAmount="@cartState.TotalAmount"
    RemoveFromCart="async (productId) => await CartService.RemoveItemAsync(productId)"
    Checkout="async () => await GoToCheckout()" />

<KhachLinkLayout>
    <!-- Hero Section -->
    <VanAnCard CssClass="hero-section text-center py-5 mb-4">
        <div class="container">
            <h1 class="display-4 fw-bold mb-3">
                <i class="bi bi-link-45deg"></i> KhachLink
            </h1>
            <p class="lead mb-4">Cỗ máy O2O Flywheel - Giữ khách & Tăng doanh thu</p>
            <div class="d-flex justify-content-center gap-3">
                <VanAnButton Icon="cart" OnClick="@(() => Navigation.NavigateTo("/cart"))">
                    Xem Giỏ Hàng
                </VanAnButton>
                <VanAnButton Variant="ButtonVariant.Outline" Icon="phone" OnClick="@(() => Navigation.NavigateTo("/contact"))">
                    Liên Hệ
                </VanAnButton>
            </div>
        </div>
    </VanAnCard>

    <!-- Stats Section -->
    <VanAnCard CssClass="stats-section mb-4">
        <div class="container">
            <div class="row text-center">
                <div class="col-md-3">
                    <div class="stat-item">
                        <i class="bi bi-people text-primary fs-1"></i>
                        <h3>1,234</h3>
                        <p>Khách hàng</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <i class="bi bi-cart text-success fs-1"></i>
                        <h3>567</h3>
                        <p>Đơn hàng</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <i class="bi bi-star text-warning fs-1"></i>
                        <h3>4.8</h3>
                        <p>Đánh giá</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <i class="bi bi-coin text-info fs-1"></i>
                        <h3>@cartState.GetTotalItems()</h3>
                        <p>Sản phẩm</p>
                    </div>
                </div>
            </div>
        </div>
    </VanAnCard>

    <!-- Product Showcase -->
    <VanAnCard CssClass="products-section mb-4">
        <div class="container">
            <h2 class="text-center mb-4">Sản Phẩm Nổi Bật</h2>
            <div class="row">
                @if (products != null && products.Any())
                {
                    @foreach (var item in products)
                    {
                        <div class="col-md-4 mb-3">
                            <VanAnCard CssClass="product-card h-100">
                                <div class="product-image">
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? $"https://placehold.co/400x300?text={System.Uri.EscapeDataString(item.Name)}" : item.ImageUrl)" 
                                         class="card-img-top" 
                                         alt="@item.Name" 
                                         style="height: 200px; object-fit: cover;" />
                                </div>
                                <div class="product-info">
                                    <h5>@item.Name</h5>
                                    <p class="text-muted">@item.Description</p>
                                    <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <span class="h5 text-primary mb-0">@item.Price.ToString("N0")đ</span>
                                                    <br />
                                                    <small class="text-muted">VAT: @(item.VatRate * 100)%</small>
                                                </div>
                                                <VanAnButton Size="ButtonSize.Small" Icon="cart-plus" OnClick="@(() => AddToCart(item))">
                                                    Đặt ngay
                                                </VanAnButton>
                                            </div>
                                </div>
                            </VanAnCard>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center">
                        <VanAnAlert Variant="AlertVariant.Info" Message="Đang tải sản phẩm..." />
                    </div>
                }
            </div>
        </div>
    </VanAnCard>
</KhachLinkLayout>

@code {
    private VanAn.KhachLink.Services.CartState cartState = null!;
    private List<Product> products = new();

    protected override async Task OnInitializedAsync()
    {
        cartState = CartService.GetCartState();
        CartService.OnCartChanged += StateHasChanged;
        await CartService.LoadCartFromStorageAsync();
        LoadProducts();
    }

    private void LoadProducts()
    {
        try
        {
            // TODO: Replace with actual API call
            var tenantId = new TenantId(Guid.NewGuid()); // Demo tenant
            products = new List<Product>
            {
                new Product(tenantId, "Trà Sua Matcha", "Trà sua matcha dam da nguyen ban tu Nhat Ban", 45000m, "Matcha", true, null, 0.10m),
                new Product(tenantId, "Trà Sua Dau Do", "Trà sua dau do ngot ngao, beo ngay", 40000m, "Traditional", true, null, 0.08m),
                new Product(tenantId, "Trà Sua Truyen Thong", "Trà sua truyen thong viêt nam", 35000m, "Traditional", true, null, 0.05m),
                new Product(tenantId, "Trà Suka Chanh", "Trà sua chanh thanh mat", 38000m, "Fruit", true, null, 0.05m)
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading products: {ex.Message}");
        }
    }

    private async Task AddToCart(Product product)
    {
        await CartService.AddItemAsync(product, 1);
        
        // Show notification
        await ShowNotification($"Đã thêm {product.Name} vào giỏ hàng!", "success");
    }

    private async Task ShowNotification(string message, string type)
    {
        // Simple notification - could be enhanced with a proper toast library
        await Task.Delay(100);
    }

    private void GoToCart()
    {
        Navigation.NavigateTo("/cart");
    }

    private async Task GoToCheckout()
    {
        Navigation.NavigateTo("/checkout");
        await Task.Delay(100);
    }

    public void Dispose()
    {
        CartService.OnCartChanged -= StateHasChanged;
    }
}
