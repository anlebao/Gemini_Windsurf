@using VanAn.Shared.Domain
@using VanAn.KhachLink.Models
@using VanAn.KhachLink.Components.Shared
@using VanAn.UI.Platform.Components.Atomic
@using VanAn.UI.Platform.Tokens
@using System.Globalization

@if (CartItems.Any())
{
    <VanAnCard CssClass="cart-drawer-card" Shadow="true">
        <HeaderContent>
            <div class="d-flex justify-content-between align-items-center w-100">
                <h5 class="mb-0 text-white">🛒 Giỏ hàng của bạn</h5>
                <VanAnButton Variant="ButtonVariant.Ghost" 
                           Size="ButtonSize.Small"
                           Icon="chevron-down"
                           OnClick="ToggleCart" />
            </div>
        </HeaderContent>
        
        @if (isCartOpen)
        {
            <div class="cart-items-container">
                @foreach (var item in CartItems ?? new List<CartItem>())
                {
                    <div class="cart-item-row" key="@item.Id">
                        <VanAnCard CssClass="cart-item-card" Shadow="false">
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="cart-item-info">
                                    <span class="cart-item-name">@(item?.ProductName ?? "Sản phẩm")</span>
                                    <span class="cart-item-quantity">x @(item?.Quantity ?? 0)</span>
                                </div>
                                <div class="cart-item-actions">
                                    <span class="cart-item-price">@CurrencyHelper.FormatVND((item?.Quantity ?? 0) * (item?.UnitPrice ?? 0m))</span>
                                    <VanAnButton Variant="ButtonVariant.Error" 
                                               Size="ButtonSize.Small"
                                               OnClick="() => RemoveFromCart?.Invoke(item?.ProductId ?? Guid.Empty)">
                                        ✕
                                    </VanAnButton>
                                </div>
                            </div>
                        </VanAnCard>
                    </div>
                }
                
                <div class="cart-total-section">
                    <VanAnCard CssClass="cart-total-card" Shadow="false">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span>Tổng cộng:</span>
                            <strong class="text-success">@CurrencyHelper.FormatVND(TotalAmount)</strong>
                        </div>
                        <VanAnButton Variant="ButtonVariant.Success" 
                                   Size="ButtonSize.Large"
                                   FullWidth="true"
                                   OnClick="async () => await Checkout()">
                            Thanh toán
                        </VanAnButton>
                    </VanAnCard>
                </div>
            </div>
        }
    </VanAnCard>
}

<style>
    .cart-drawer-card {
        position: fixed;
        right: 20px;
        top: 100px;
        width: 350px;
        max-height: 70vh;
        z-index: 1000;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    
    .cart-drawer-card ::deep .card-header {
        background: transparent;
        border-bottom: none;
    }
    
    .cart-items-container {
        max-height: 400px;
        overflow-y: auto;
        background: white;
    }
    
    .cart-item-row {
        border-bottom: 1px solid #eee;
    }
    
    .cart-item-row:last-child {
        border-bottom: none;
    }
    
    .cart-item-card {
        border: none;
        border-radius: 0;
    }
    
    .cart-item-card ::deep .card-body {
        padding: 15px;
    }
    
    .cart-item-info {
        flex: 1;
    }
    
    .cart-item-name {
        font-weight: 500;
        display: block;
        color: #333;
    }
    
    .cart-item-quantity {
        color: #666;
        font-size: 0.9rem;
    }
    
    .cart-item-actions {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .cart-item-price {
        font-weight: bold;
        color: #28a745;
        font-size: 1.1rem;
    }
    
    .cart-total-section {
        background: #f8f9fa;
    }
    
    .cart-total-card {
        background: transparent;
        border: none;
        border-radius: 0;
    }
    
    .cart-total-card ::deep .card-body {
        padding: 20px;
    }
    
    @@media (max-width: 768px) {
        .cart-drawer-card {
            position: static;
            width: 100%;
            margin: 20px 0;
            right: auto;
            top: auto;
        }
    }
</style>

@code {
    [Parameter]
    public List<CartItem> CartItems { get; set; } = new();
    
    [Parameter]
    public decimal TotalAmount { get; set; }
    
    [Parameter]
    public Action<Guid>? RemoveFromCart { get; set; }
    
    [Parameter, EditorRequired]
    public Func<Task> Checkout { get; set; } = default!;
    
    private bool isCartOpen = true;

    private void ToggleCart()
    {
        isCartOpen = !isCartOpen;
    }
}
