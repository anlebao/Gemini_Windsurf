@using VanAn.UI.Platform.Components.Atomic
@using VanAn.UI.Platform.Components.Composite
@using VanAn.UI.Platform.Tokens
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<VanAnModal IsOpen="true" 
          Title="Thanh toán qua VietQR" 
          OnClose="OnPaymentCompleted"
          Closable="true">
    <div class="qr-modal-content text-center">
        @if (IsLoading)
        {
            <div class="loading-container">
                <span class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Đang tạo mã QR...</span>
                </span>
                <p class="mt-3">Đang tạo mã QR thanh toán...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(QrImageUrl))
        {
            <VanAnCard CssClass="qr-info-card" Shadow="true">
                <div class="qr-image-container">
                    <img src="@QrImageUrl" alt="VietQR Payment Code" class="qr-image" />
                </div>
                <div class="qr-info mt-3">
                    <h6>Thông tin thanh toán</h6>
                    <p class="mb-1"><strong>Số tiền:</strong> @Amount.ToString("N0")đ</p>
                    <p class="mb-1"><strong>Mã đơn hàng:</strong> @OrderId</p>
                    <p class="mb-1"><strong>Ngân hàng:</strong> @BankName</p>
                    <p class="mb-0"><small class="text-muted">Quét mã QR bằng ứng dụng ngân hàng để thanh toán</small></p>
                </div>
            </VanAnCard>
        }
        else if (Error != null)
        {
            <VanAnCard CssClass="error-card" Shadow="true">
                <div class="text-danger">
                    <i class="fas fa-exclamation-triangle"></i>
                    <span class="ms-2">@Error</span>
                </div>
            </VanAnCard>
        }
    </div>
    
    <FooterContent>
        <VanAnButton Variant="ButtonVariant.Secondary" 
                   OnClick="OnPaymentCompleted">
            Đóng
        </VanAnButton>
        @if (!string.IsNullOrEmpty(QrImageUrl))
        {
            <VanAnButton Variant="ButtonVariant.Primary" 
                       Icon="download"
                       OnClick="DownloadQr">
                Lưu mã QR
            </VanAnButton>
        }
    </FooterContent>
</VanAnModal>

<style>
    .qr-modal-content {
        padding: 20px;
    }
    
    .loading-container {
        padding: 40px 20px;
    }
    
    .qr-image {
        max-width: 300px;
        max-height: 300px;
        border: 2px solid #e9ecef;
        border-radius: 8px;
    }
    
    .qr-info-card {
        background: #f8f9fa;
        padding: 20px;
    }
    
    .qr-info-card ::deep .card-body {
        padding: 0;
    }
    
    .error-card ::deep .card-body {
        padding: 20px;
        background: #f8d7da;
        border: 1px solid #f5c6cb;
        border-radius: 4px;
    }
</style>

@code {
    [Parameter]
    public decimal Amount { get; set; }
    
    [Parameter]
    public string OrderId { get; set; } = string.Empty;
    
    [Parameter]
    public EventCallback OnPaymentCompleted { get; set; }

    private bool IsLoading { get; set; } = false;
    private string? QrImageUrl { get; set; }
    private string? BankName { get; set; }
    private string? Error { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (Amount > 0 && !string.IsNullOrEmpty(OrderId))
        {
            await GenerateQrCode();
        }
    }

    private async Task GenerateQrCode()
    {
        IsLoading = true;
        Error = null;
        QrImageUrl = null;

        try
        {
            // Default bank configuration (could be from shop settings)
            var bankConfig = new
            {
                BankId = "970422", // Vietcombank
                AccountNo = "1234567890",
                AccountName = "VAN AN COFFEE"
            };

            var request = new
            {
                Amount = Amount,
                OrderDescription = OrderId,
                BankConfig = bankConfig
            };

            var response = await Http.PostAsJsonAsync("/api/v1/vietqr/generate", request);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<VietQrResponse>();
                QrImageUrl = result?.QrImageUrl;
                BankName = "Vietcombank";
            }
            else
            {
                Error = "Không thể tạo mã QR. Vui lòng thử lại.";
            }
        }
        catch (Exception)
        {
            Error = "Lỗi kết nối. Vui lòng kiểm tra mạng và thử lại.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task DownloadQr()
    {
        if (!string.IsNullOrEmpty(QrImageUrl))
        {
            await JSRuntime.InvokeVoidAsync("downloadImage", QrImageUrl, $"QR_{OrderId}.jpg");
        }
    }

    public class VietQrResponse
    {
        public string QrImageUrl { get; set; } = string.Empty;
        public string PaymentUrl { get; set; } = string.Empty;
        public decimal Amount { get; set; }
        public string OrderId { get; set; } = string.Empty;
    }
}
