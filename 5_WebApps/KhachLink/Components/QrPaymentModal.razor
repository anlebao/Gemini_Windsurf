@inject HttpClient Http
@inject IJSRuntime JSRuntime

<div class="modal fade" id="qrPaymentModal" tabindex="-1" aria-labelledby="qrPaymentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="qrPaymentModalLabel">
                    <i class="fas fa-qrcode"></i> Thanh toán qua VietQR
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                @if (IsLoading)
                {
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Đang tạo mã QR...</span>
                    </div>
                    <p class="mt-2">Đang tạo mã QR thanh toán...</p>
                }
                else if (!string.IsNullOrEmpty(QrImageUrl))
                {
                    <div class="qr-container">
                        <img src="@QrImageUrl" alt="VietQR Payment Code" class="img-fluid qr-image" />
                        <div class="mt-3">
                            <h6>Thông tin thanh toán</h6>
                            <p class="mb-1"><strong>Số tiền:</strong> @Amount.ToString("N0")đ</p>
                            <p class="mb-1"><strong>Mã đơn hàng:</strong> @OrderId</p>
                            <p class="mb-1"><strong>Ngân hàng:</strong> @BankName</p>
                            <p class="mb-0"><small class="text-muted">Quét mã QR bằng ứng dụng ngân hàng để thanh toán</small></p>
                        </div>
                    </div>
                }
                else if (Error != null)
                {
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-triangle"></i>
                        @Error
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                @if (!string.IsNullOrEmpty(QrImageUrl))
                {
                    <button type="button" class="btn btn-primary" @onclick="DownloadQr">
                        <i class="fas fa-download"></i> Lưu mã QR
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .qr-image {
        max-width: 300px;
        max-height: 300px;
        border: 2px solid #e9ecef;
        border-radius: 8px;
    }
    
    .qr-container {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 8px;
    }
</style>

@code {
    [Parameter]
    public decimal Amount { get; set; }
    
    [Parameter]
    public string OrderId { get; set; } = string.Empty;
    
    [Parameter]
    public EventCallback OnPaymentCompleted { get; set; }

    private bool IsLoading { get; set; } = false;
    private string? QrImageUrl { get; set; }
    private string? BankName { get; set; }
    private string? Error { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (Amount > 0 && !string.IsNullOrEmpty(OrderId))
        {
            await GenerateQrCode();
        }
    }

    private async Task GenerateQrCode()
    {
        IsLoading = true;
        Error = null;
        QrImageUrl = null;

        try
        {
            // Default bank configuration (could be from shop settings)
            var bankConfig = new
            {
                BankId = "970422", // Vietcombank
                AccountNo = "1234567890",
                AccountName = "VAN AN COFFEE"
            };

            var request = new
            {
                Amount = Amount,
                OrderDescription = OrderId,
                BankConfig = bankConfig
            };

            var response = await Http.PostAsJsonAsync("/api/v1/vietqr/generate", request);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<VietQrResponse>();
                QrImageUrl = result?.QrImageUrl;
                BankName = "Vietcombank";
            }
            else
            {
                Error = "Không thể tạo mã QR. Vui lòng thử lại.";
            }
        }
        catch (Exception)
        {
            Error = "Lỗi kết nối. Vui lòng kiểm tra mạng và thử lại.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task DownloadQr()
    {
        if (!string.IsNullOrEmpty(QrImageUrl))
        {
            await JSRuntime.InvokeVoidAsync("downloadImage", QrImageUrl, $"QR_{OrderId}.jpg");
        }
    }

    public class VietQrResponse
    {
        public string QrImageUrl { get; set; } = string.Empty;
        public string PaymentUrl { get; set; } = string.Empty;
        public decimal Amount { get; set; }
        public string OrderId { get; set; } = string.Empty;
    }
}
