@using VanAn.UI.Platform.Components.Atomic
@using VanAn.UI.Platform.Tokens
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject ILocalizationService LocalizationService

<VanAnCard CssClass="voice-command-card" Shadow="true">
    @if (isRecording)
    {
        <div class="recording-indicator">
            <div class="recording-dot"></div>
            <span>@LocalizationService.GetString("Voice.Recording")</span>
            <VanAnButton Variant="ButtonVariant.Error" 
                       Size="ButtonSize.Small"
                       OnClick="StopRecording">
                ⏹️ @LocalizationService.GetString("Voice.StopRecording")
            </VanAnButton>
        </div>
    }
    else
    {
        <div class="voice-controls">
            <VanAnButton Variant="ButtonVariant.Primary" 
                       OnClick="StartRecording"
                       Disabled="string.IsNullOrEmpty(currentOrderId)">
                🎤 @LocalizationService.GetString("Voice.StartRecording")
            </VanAnButton>
            <select class="language-select" @bind="selectedLanguage" @bind:after="OnLanguageChanged">
                <option value="vi">@LocalizationService.GetString("Voice.Vietnamese")</option>
                <option value="en">@LocalizationService.GetString("Voice.English")</option>
            </select>
        </div>
    }
    
    @if (!string.IsNullOrEmpty(transcript))
    {
        <VanAnCard CssClass="transcript-card mt-3" Shadow="false">
            <small class="text-muted">@LocalizationService.GetString("Voice.Transcript"):</small>
            <p class="transcript-text">@transcript</p>
        </VanAnCard>
    }
</VanAnCard>

<style>
    .voice-command-card {
        margin: 1rem 0;
    }
    
    .voice-command-card ::deep .card-body {
        padding: 1rem;
    }
    
    .recording-indicator {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .recording-dot {
        width: 12px;
        height: 12px;
        background-color: #dc3545;
        border-radius: 50%;
        animation: pulse 1.5s infinite;
    }
    
    @@keyframes pulse {
        0% {
            transform: scale(0.95);
            box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7);
        }
        
        70% {
            transform: scale(1);
            box-shadow: 0 0 0 10px rgba(220, 53, 69, 0);
        }
        
        100% {
            transform: scale(0.95);
            box-shadow: 0 0 0 0 rgba(220, 53, 69, 0);
        }
    }
    
    .voice-controls {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .language-select {
        padding: 0.375rem 0.75rem;
        border-radius: 0.25rem;
        border: 1px solid #ced4da;
        font-size: 0.875rem;
    }
    
    .transcript-card {
        background-color: #f8f9fa;
        border-left: 4px solid #007bff;
    }
    
    .transcript-card ::deep .card-body {
        padding: 0.75rem;
    }
    
    .transcript-text {
        margin: 0.25rem 0 0 0;
    }
</style>

@code {
    [Parameter]
    public string OrderId { get; set; } = string.Empty;
    
    [Parameter]
    public EventCallback<string> OnTranscriptChanged { get; set; }

    private bool isRecording = false;
    private string transcript = "";
    private string currentOrderId = "";
    private string selectedLanguage = "vi";

    protected override async Task OnParametersSetAsync()
    {
        currentOrderId = OrderId;
        await Task.CompletedTask;
    }

    private void OnLanguageChanged()
    {
        LocalizationService.SetCulture(selectedLanguage);
        StateHasChanged();
    }

    private async Task StartRecording()
    {
        try
        {
            isRecording = true;
            StateHasChanged();

            // Start recording using Web Speech API with selected language
            await JSRuntime.InvokeVoidAsync("startVoiceRecording", DotNetObjectReference.Create(this), selectedLanguage);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error starting recording: {ex.Message}");
            isRecording = false;
            StateHasChanged();
        }
    }

    private async Task StopRecording()
    {
        try
        {
            isRecording = false;
            StateHasChanged();

            // Stop recording
            await JSRuntime.InvokeVoidAsync("stopVoiceRecording");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error stopping recording: {ex.Message}");
        }
    }

    [JSInvokable]
    public async Task OnRecordingComplete(string transcriptText)
    {
        transcript = transcriptText;
        isRecording = false;
        
        // Update order note with transcript
        await UpdateOrderNote(transcriptText);
        
        // Notify parent component
        await OnTranscriptChanged.InvokeAsync(transcriptText);
        
        StateHasChanged();
    }

    private async Task UpdateOrderNote(string note)
    {
        try
        {
            if (!string.IsNullOrEmpty(currentOrderId))
            {
                // Update order note via API
                var updateData = new { OrderNote = note };
                await Http.PutAsJsonAsync($"/api/v1/orders/{currentOrderId}/note", updateData);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating order note: {ex.Message}");
        }
    }
}
