@inject IJSRuntime JSRuntime

<div class="social-bridge-section my-4">
    <h3 class="text-center mb-4">Kết nối cộng đồng</h3>
    
    <div class="row">
        <!-- Facebook Feed -->
        <div class="col-md-6 mb-3">
            <div class="social-card">
                <h5><i class="fab fa-facebook"></i> Facebook</h5>
                <div class="social-embed">
                    @if (!string.IsNullOrEmpty(ShopConfig?.SocialLinksFb))
                    {
                        <iframe 
                            src="@GetFacebookEmbedUrl(ShopConfig.SocialLinksFb)"
                            width="100%" 
                            height="300" 
                            style="border:none;overflow:hidden"
                            scrolling="no"
                            frameborder="0"
                            allowfullscreen="true"
                            allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share">
                        </iframe>
                    }
                    else
                    {
                        <div class="text-muted text-center p-3">
                            <i class="fab fa-facebook fa-3x mb-2"></i>
                            <p>Chưa kết nối Facebook</p>
                        </div>
                    }
                </div>
            </div>
        </div>
        
        <!-- TikTok Feed -->
        <div class="col-md-6 mb-3">
            <div class="social-card">
                <h5><i class="fab fa-tiktok"></i> TikTok</h5>
                <div class="social-embed">
                    @if (!string.IsNullOrEmpty(ShopConfig?.SocialLinksTiktok))
                    {
                        <blockquote class="tiktok-embed" cite="@ShopConfig.SocialLinksTiktok" data-video-id="@GetTikTokVideoId(ShopConfig.SocialLinksTiktok)" style="max-width: 605px;min-width: 325px;">
                            <section>&nbsp;</section>
                        </blockquote>
                        <script async src="https://www.tiktok.com/embed.js"></script>
                    }
                    else
                    {
                        <div class="text-muted text-center p-3">
                            <i class="fab fa-tiktok fa-3x mb-2"></i>
                            <p>Chưa kết nối TikTok</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public ShopConfig ShopConfig { get; set; }

    private string GetFacebookEmbedUrl(string facebookUrl)
    {
        // Convert Facebook post/page URL to embed URL
        if (facebookUrl.Contains("/posts/"))
        {
            var postId = facebookUrl.Split("/posts/").Last().Split('?').First();
            return $"https://www.facebook.com/plugins/post.php?href={Uri.EscapeDataString(facebookUrl)}&show_posts=true&width=100%";
        }
        else if (facebookUrl.Contains("/pages/"))
        {
            return $"https://www.facebook.com/plugins/page.php?href={Uri.EscapeDataString(facebookUrl)}&tabs=timeline&width=100%&height=300&small_header=false&adapt_container_width=true&hide_cover=false&show_facepile=true&appId";
        }
        return facebookUrl;
    }

    private string GetTikTokVideoId(string tiktokUrl)
    {
        // Extract video ID from TikTok URL
        if (tiktokUrl.Contains("/video/"))
        {
            return tiktokUrl.Split("/video/").Last().Split('?').First();
        }
        return "";
    }
}

<style>
.social-bridge-section {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 15px;
    padding: 2rem;
    color: white;
}

.social-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border-radius: 10px;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
}

.social-embed {
    border-radius: 8px;
    overflow: hidden;
}

.social-embed iframe {
    border-radius: 8px;
}
</style>
