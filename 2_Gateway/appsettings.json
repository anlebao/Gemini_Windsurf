{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=VanAnCoreHub;Username=vanan_admin;Password=VanAn@2024!",
    "Nats": "nats://localhost:4222"
  },
  "Nats": {
    "Url": "nats://localhost:4222",
    "MaxReconnects": 10,
    "ReconnectWait": 2000,
    "ConnectionTimeout": 5000
  },
  "CoreHub": {
    "BaseUrl": "http://localhost:5001"
  },
  "Authentication": {
    "JwtSettings": {
      "SecretKey": "VanAnEcosystem2024SecretKeyForJWTTokenGeneration",
      "Issuer": "VanAn.Gateway",
      "Audience": "VanAn.Clients",
      "ExpirationMinutes": 60
    },
    "DeviceIdValidation": {
      "AllowZeroFriction": true,
      "RequireBiometricForStaff": true
    }
  },
  "ReverseProxy": {
    "Routes": {
      "khachlink-route": {
        "ClusterId": "khachlink-cluster",
        "Match": {
          "Path": "/khachlink/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/khachlink" }
        ]
      },
      "shoperp-route": {
        "ClusterId": "shoperp-cluster",
        "Match": {
          "Path": "/shoperp/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/shoperp" }
        ]
      },
      "corehub-route": {
        "ClusterId": "corehub-cluster",
        "Match": {
          "Path": "/corehub/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/corehub" }
        ]
      },
      "fallback-route": {
        "ClusterId": "khachlink-cluster",
        "Match": {
          "Path": "{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "corehub-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://corehub:80/"
          }
        }
      },
      "khachlink-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://khachlink:80/"
          }
        }
      },
      "shoperp-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://shoperp:80/"
          }
        }
      }
    }
  }
}
