# VanAn Ecosystem - Git Ignore File
# Optimized for .NET 8.0, MAUI, Docker, and Multi-project Solution

# ========================================
# .NET & Build Artifacts
# ========================================
# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/

# Visual Studio 2017 auto generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build Results of an ATL Project
[Dd]ebugPS/
*.rej
*.vspc
.cec
*.vg
*.pgc
*.pgc
*.pgp
*.vs1

# Strong Name tool
sn.exe
sn.pdb

# A .NET user project settings
*.user
*.suo
*.userosscache
*.sln.docstates

# Mono auto generated files
mono_crash.*

# Mac xDeps
*.xdeps/

# ========================================
# .NET MAUI Specific
# ========================================
# MAUI cache and build files
**/*.maui/
**/*.maui.cache/
**/*.maui.resources/
**/*.resx.cache/

# Platform-specific build outputs
**/bin/
**/obj/
**/packages/

# MAUI Android specific
**/platforms/android/*/bin/
**/platforms/android/*/obj/
**/platforms/android/**/*.jar
**/platforms/android/**/*.aar

# MAUI iOS specific
**/platforms/ios/*/bin/
**/platforms/ios/*/obj/
**/platforms/ios/**/*.dll
**/platforms/ios/**/*.dylib

# MAUI Windows specific
**/platforms/windows/*/bin/
**/platforms/windows/*/obj/
**/platforms/windows/**/*.exe
**/platforms/windows/**/*.dll

# ========================================
# NuGet Packages
# ========================================
*.nupkg
# NuGet Symbol Packages
*.snupkg
# The packages folder can be ignored when building with MSBuild.
# Rider will use the solution's packages folder, so this should not be ignored.
**/packages/*
# except packages folder in the root of the repository
!packages/
# NuGet v3's project.json files produce more ignorable files
*.nuget.props
*.nuget.targets
*.nuget.exe
*.nuget.config

# ========================================
# Rider IDE
# ========================================
# Rider-specific files are ignored by default
.idea/
*.sln.iml

# ========================================
# Visual Studio Code
# ========================================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# Local History for Visual Studio Code
.history/

# Built Visual Studio Code Extensions
*.vsix

# ========================================
# Windows
# ========================================
# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Windows Installer files
*.cab
*.msi
*.msix
*.msm
*.msp

# Windows shortcuts
*.lnk

# ========================================
# macOS
# ========================================
# General
.DS_Store?
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# ========================================
# Linux
# ========================================
*~

# temporary files which can be created if a process still has a handle open of a deleted file
.fuse_hidden*

# KDE directory preferences
.directory

# Linux trash folder which might appear on any partition or disk
.Trash-*

# .nfs files are created when an open file is removed but is still being accessed
.nfs*

# ========================================
# Docker
# ========================================
# Dockerignore files (keep .dockerignore)
# Docker volumes
docker-compose.override.yml
docker-compose.local.yml
docker-compose.dev.yml
.env.local
.env.development
.env.production

# Docker build cache
.docker/

# ========================================
# Database
# ========================================
# SQLite database files
*.db
*.sqlite
*.sqlite3

# PostgreSQL
*.sql.gz
*.dump

# Database backups
*.bak
*.backup

# Local database files
**/App_Data/
**/Data/

# ========================================
# Logs and Runtime
# ========================================
# Log files
*.log
*.txt.log

# Runtime files
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# ========================================
# Node.js (for JavaScript/TypeScript parts)
# ========================================
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# TypeScript v1 declaration files
typings/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
public

# Storybook build outputs
.out
.storybook-out

# Temporary folders
tmp/
temp/

# ========================================
# Configuration Files (Keep some, ignore others)
# ========================================
# Local configuration files
appsettings.local.json
appsettings.Development.local.json
appsettings.Production.local.json

# Environment files (keep .env.test)
.env.local
.env.development.local
.env.test.local
.env.production.local

# ========================================
# IDE and Editor Files
# ========================================
# Vim
*.swp
*.swo

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ========================================
# Project Specific
# ========================================
# Build logs
build.log
khachlink_errors.txt

# Temporary files
*.tmp
*.temp

# Cache directories
cache/
.Cache/

# Local development files
start-vanan.ps1.local
Restart-VanAnEcosystem.ps1.local

# Test results
TestResults/
!TestResults/full-results.trx
coverage/
!coverage/**/*.opencover.xml
!coverage/**/*.cobertura.xml

# Documentation build artifacts
docs/_build/
docs/.cache/

# ========================================
# Windsurf Specific
# ========================================
# Keep windsurf rules
!.windsurfrules
.windsurf/cache/
.windsurf/tmp/

# ========================================
# Custom Exceptions (Files to Keep)
# ========================================
# Keep important configuration files
!.dockerignore
!.editorconfig
!.env.test
!Directory.Build.props
!VanAn.sln
!windsurf-guard.js
!start-dashboard.js

# Keep documentation
!docs/
!*.md

# Keep scripts
!scripts/
!run-all.bat

# Keep diagrams
!Diagrams/

# Keep rules
!.rules/
!.windsurf/

# ========================================
# End of VanAn Ecosystem .gitignore
# ========================================
