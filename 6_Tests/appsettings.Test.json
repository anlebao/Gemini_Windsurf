{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=vanan_test;Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}",
    "Postgres": "Host=localhost;Port=5432;Database=vanan_test;Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}",
    "Nats": "nats://localhost:4222"
  },
  "Postgres": {
    "Host": "localhost",
    "Port": 5432,
    "Database": "vanan_test",
    "Username": "${POSTGRES_USER}",
    "Password": "${POSTGRES_PASSWORD}",
    "SslMode": "Prefer",
    "TrustServerCertificate": true,
    "CommandTimeout": 30,
    "EnableRetryOnFailure": true,
    "MaxRetryCount": 3
  },
  "Nats": {
    "Url": "nats://localhost:4222",
    "MaxReconnects": 10,
    "ReconnectWait": 2000,
    "ConnectionTimeout": 5000,
    "EnableJetStream": true
  },
  "OutboxPattern": {
    "Enabled": true,
    "PollingInterval": 5000,
    "BatchSize": 100,
    "MaxRetryAttempts": 3,
    "RetryDelay": 30000
  },
  "Sync": {
    "Enabled": true,
    "SyncInterval": 30000,
    "BatchSize": 50
  }
}
